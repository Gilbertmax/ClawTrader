# ─────────────────────────────────────────────
# ClawTrader — Configuración de APIs
# Copia este archivo como .env y completa tus keys
# NUNCA subas .env a GitHub
# ─────────────────────────────────────────────

# --- BINANCE SPOT (REAL) ---
# Crea tus API keys en: https://www.binance.com/es/my/settings/api-management
# Necesitas: Enable Reading + Enable Spot & Margin Trading
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# --- TELEGRAM (opcional, para notificaciones) ---
# Crea un bot con @BotFather en Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- SEGURIDAD / OPERACION ---
# Por defecto ClawTrader NO debe mandar ordenes reales.
CLAWTRADER_DRY_RUN=true
CLAWTRADER_LIVE_TRADING=false
CLAWTRADER_CAPITAL=1000
# CLAWTRADER_STATUS_DIR=~/.openclaw/workspace/state
# CLAWTRADER_TRADES_FILE=~/.openclaw/workspace/state/trades_db.json
# CLAWTRADER_ENGINE_FILE=~/.openclaw/workspace/state/live_engine_state.json
# CLAWTRADER_ENTRY_WATCH_FILE=~/.openclaw/workspace/state/entry_watcher_targets.json
